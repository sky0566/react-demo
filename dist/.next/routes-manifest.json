      "regex": "^/api/categories/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/categories/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/partners/[id]",
